# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=loan-risk

# Serving
SERVING_PORT=8000
SERVING_MODEL_ALIAS=champion

# Data paths
DATA_DIR=data
ARTIFACTS_DIR=artifacts
REPORTS_DIR=reports

# Training
TRAINING_RANDOM_SEED=42
TRAINING_TEST_SIZE=0.20
TRAINING_VAL_SIZE=0.10
TRAINING_N_TRIALS=100

# Monitoring
MONITORING_DRIFT_PSI_THRESHOLD=0.15
