{
  "widgets": [
    {
      "type": "metric",
      "x": 0,
      "y": 0,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Prediction Volume",
        "view": "timeSeries",
        "stacked": false,
        "metrics": [
          ["LoanRisk", "PredictionCount", { "stat": "Sum", "period": 300, "label": "Predictions/5min" }]
        ],
        "region": "us-east-1",
        "period": 300
      }
    },
    {
      "type": "metric",
      "x": 12,
      "y": 0,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "P99 Prediction Latency",
        "view": "timeSeries",
        "metrics": [
          ["LoanRisk", "PredictionLatency", { "stat": "p99", "period": 300, "label": "P99 Latency (ms)" }],
          ["LoanRisk", "PredictionLatency", { "stat": "Average", "period": 300, "label": "Avg Latency (ms)" }]
        ],
        "region": "us-east-1"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 6,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Default Probability Distribution",
        "view": "timeSeries",
        "metrics": [
          ["LoanRisk", "DefaultProbability", { "stat": "Average", "period": 300, "label": "Avg Default Prob" }],
          ["LoanRisk", "DefaultProbability", { "stat": "p95", "period": 300, "label": "P95 Default Prob" }]
        ],
        "region": "us-east-1",
        "annotations": {
          "horizontal": [{ "value": 0.5, "label": "Decision threshold", "color": "#ff9900" }]
        }
      }
    },
    {
      "type": "metric",
      "x": 12,
      "y": 6,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Feature PSI (Data Drift)",
        "view": "timeSeries",
        "metrics": [
          ["LoanRisk", "PSI", { "stat": "Maximum", "period": 3600, "label": "Max PSI" }]
        ],
        "region": "us-east-1",
        "annotations": {
          "horizontal": [
            { "value": 0.15, "label": "Warning threshold", "color": "#ff9900" },
            { "value": 0.30, "label": "Critical threshold", "color": "#ff0000" }
          ]
        }
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 12,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Live AUC",
        "view": "timeSeries",
        "metrics": [
          ["LoanRisk", "LiveAUC", { "stat": "Average", "period": 3600, "label": "Live AUC" }]
        ],
        "region": "us-east-1",
        "annotations": {
          "horizontal": [{ "value": 0.75, "label": "AUC threshold", "color": "#ff0000" }]
        }
      }
    },
    {
      "type": "metric",
      "x": 12,
      "y": 12,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "ECS CPU & Memory Utilization",
        "view": "timeSeries",
        "metrics": [
          ["AWS/ECS", "CPUUtilization",    "ClusterName", "loan-risk-cluster", "ServiceName", "loan-risk-serving", { "stat": "Average", "label": "CPU %" }],
          ["AWS/ECS", "MemoryUtilization", "ClusterName", "loan-risk-cluster", "ServiceName", "loan-risk-serving", { "stat": "Average", "label": "Memory %" }]
        ],
        "region": "us-east-1"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 18,
      "width": 24,
      "height": 6,
      "properties": {
        "title": "ALB Request Count & 5xx Errors",
        "view": "timeSeries",
        "metrics": [
          ["AWS/ApplicationELB", "RequestCount",             { "stat": "Sum", "period": 60, "label": "Requests/min" }],
          ["AWS/ApplicationELB", "HTTPCode_Target_5XX_Count", { "stat": "Sum", "period": 60, "label": "5xx Errors/min", "color": "#ff0000" }]
        ],
        "region": "us-east-1"
      }
    }
  ]
}
